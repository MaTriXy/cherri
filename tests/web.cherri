// --- HTTP ---

const response = downloadURL("https://api.example.com/data")
const authed = downloadURL("https://api.example.com/data", {"Authorization": "Bearer my-token"})

const created = jsonRequest("https://api.example.com/items", "POST", {"name": "Test", "active": true})
const authedPost = jsonRequest("https://api.example.com/items", "POST", {"name": "Test"}, {"Authorization": "Bearer my-token", "Accept": "application/json"})

const submitted = formRequest("https://api.example.com/submit", "POST", {"key": "value"})
const authedForm = formRequest("https://api.example.com/submit", "POST", {"key": "value"}, {"Authorization": "Bearer my-token"})

// --- URL utilities ---

const encoded = urlEncode("hello world & more")
const decoded = urlDecode("hello%20world%20%26%20more")
const expanded = expandURL("https://bit.ly/example")
const host = getURLDetail("https://api.example.com/v1/items?q=test", "Host")

// --- X-Callback URL ---

// url-only: previously panicked (bug #178)
openCustomXCallbackURL("myapp://do-something")

// all optional args: successKey, cancelKey, errorKey, successURL
openCustomXCallbackURL("myapp://do-something", "success", "cancel", "error", "myapp://done")